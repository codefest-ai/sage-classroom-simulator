# Optional LLM-backed simulation
GROQ_API_KEY=

# Required for validating signed Zoom webhook requests in hosted/live mode
ZOOM_WEBHOOK_SECRET=

# Zoom OAuth (multi-install) — enables the Connect Zoom Account button.
# Each teacher / institution authorizes the app through Zoom; their install
# is persisted on disk and the dashboard lists every connected account.
# Webhook events are routed to the matching install by Zoom account_id.
#
# - ZOOM_OAUTH_CLIENT_ID / ZOOM_OAUTH_CLIENT_SECRET come from your Zoom
#   Marketplace app (OAuth-enabled, not Webhook-Only).
# - ZOOM_OAUTH_REDIRECT_URL must exactly match the OAuth Redirect URL
#   registered in the Marketplace app (e.g.
#   https://sage-simulator-ulsd.onrender.com/api/zoom/oauth/callback).
# - ZOOM_OAUTH_STORE_DIR holds one JSON file per install. Default:
#   /tmp/sage_zoom_oauth_installs (course demo only — use a persistent
#   disk path in production).
ZOOM_OAUTH_CLIENT_ID=
ZOOM_OAUTH_CLIENT_SECRET=
ZOOM_OAUTH_REDIRECT_URL=
ZOOM_OAUTH_STORE_DIR=

# Local development only. Enables read-only Zoom REST probe endpoints:
# /api/zoom/probe, /api/zoom/probe/meetings, /api/zoom/probe/participants.
# Do not enable on public demo hosts.
ENABLE_ZOOM_API_PROBE=0
ZOOM_API_TOKEN=

# Optional session cleanup tuning (seconds)
SESSION_MAX_AGE_SEC=7200
